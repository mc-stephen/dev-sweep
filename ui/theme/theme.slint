export global Theme {
    // Base palette
    in-out property <color> accent: #6C5CE7;
    // in-out property <color> accent_light: #A29BFE;
    in-out property <color> accent_light: accent.brighter(0.3);
    // in-out property <color> accent_dark: #5641CC;
    in-out property <color> accent_dark: accent.with-alpha(0.1);
    // in-out property <color> accent_glow: #6c5ce74d; // rgba(108, 92, 231, 0.3);

    // Status colors
    in-out property <color> success: #00B894;
    // in-out property <color> success_bg: rgba(0, 184, 148, 0.12);
    in-out property <color> warning: #FDCB6E;
    // in-out property <color> warning_bg: rgba(253, 203, 110, 0.12);
    in-out property <color> danger: #E17055;
    // in-out property <color> danger_bg: rgba(225, 112, 85, 0.12);
    in-out property <color> info: #74B9FF;
    // in-out property <color> info_bg: rgba(116, 185, 255, 0.12);

    // Backgrounds
    in-out property <color> bg_primary: #0D0F12;
    in-out property <color> bg_secondary: #13161B;
    in-out property <color> bg_tertiary: #1A1D24;
    in-out property <color> bg_card: #161920;
    in-out property <color> bg_card_hover: #1C2029;
    in-out property <color> bg_elevated: #1E222B;
    in-out property <color> bg_input: #1A1D24;
    in-out property <color> bg_sidebar: #0F1115;
    in-out property <color> bg_overlay: rgba(0, 0, 0, 0.6);

    // Borders
    in-out property <color> border_primary: rgba(255, 255, 255, 0.06);
    in-out property <color> border_secondary: rgba(255, 255, 255, 0.1);
    in-out property <color> border_active: rgba(108, 92, 231, 0.5);

    // Text
    in-out property <color> text_primary: #F0F0F3;
    in-out property <color> text_secondary: #8B8FA3;
    in-out property <color> text_tertiary: #5A5E72;
    in-out property <color> text_inverse: #0D0F12;

    // Scrollbars
    in-out property <color> scrollbar_track: #13161B;
    in-out property <color> scrollbar_thumb: #2A2E3A;

    // Sizes
    in-out property <length> sidebar_width: 260px;
    in-out property <length> sidebar_collapsed: 72px;
    in-out property <length> topbar_height: 52px;
    in-out property <length> radius_sm: 8px;
    in-out property <length> radius_md: 12px;
    in-out property <length> radius_lg: 16px;
    in-out property <length> radius_xl: 20px;
    in-out property <float> radius_full: 0.5; // 50%

    // Transitions
    in-out property <duration> transition_fast: 0.15s;
    in-out property <duration> transition_normal: 0.25s;
    in-out property <duration> transition_slow: 0.4s;

    // Fonts
    in-out property <string> font_sans: "Inter, -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif";
    in-out property <string> font_mono: "JetBrains Mono, Fira Code, Cascadia Code, monospace";

    // Shadows
    in-out property <string> shadow_sm: "0 1px 2px rgba(0,0,0,0.2)";
    in-out property <string> shadow_md: "0 4px 12px rgba(0,0,0,0.25)";
    in-out property <string> shadow_lg: "0 8px 30px rgba(0,0,0,0.35)";
    in-out property <string> shadow_xl: "0 16px 50px rgba(0,0,0,0.45)";
    in-out property <color> shadow_glow: accent_dark; // #6C5CE74D; // "0 0 20px rgba(108, 92, 231, 0.3)";
}
