export global LightTheme {
    // Backgrounds
    in-out property <color> bg_primary: #F5F6FA;
    in-out property <color> bg_secondary: #FFFFFF;
    in-out property <color> bg_tertiary: #EEF0F6;
    in-out property <color> bg_card: #FFFFFF;
    in-out property <color> bg_card_hover: #F8F9FC;
    in-out property <color> bg_elevated: #FFFFFF;
    in-out property <color> bg_input: #F0F2F7;
    in-out property <color> bg_sidebar: #FFFFFF;
    in-out property <color> bg_overlay: rgba(0, 0, 0, 0.3);

    // Borders
    in-out property <color> border_primary: rgba(0, 0, 0, 0.06);
    in-out property <color> border_secondary: rgba(0, 0, 0, 0.1);
    in-out property <color> border_active: rgba(108, 92, 231, 0.5);

    // Text
    in-out property <color> text_primary: #1A1D24;
    in-out property <color> text_secondary: #5A5E72;
    in-out property <color> text_tertiary: #8B8FA3;
    in-out property <color> text_inverse: #F0F0F3;

    // Scrollbars
    in-out property <color> scrollbar_track: #F0F2F7;
    in-out property <color> scrollbar_thumb: #C8CCD8;
}
