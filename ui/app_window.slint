import { Theme } from "./theme/theme.slint";
import { ThemeType } from "theme/theme.slint";
import { Icons } from "./services/icons.slint";
import { NavItem } from "components/nav_item.slint";
import { CleanersPage } from "pages/cleaners/cleaners.slint";
import { SettingsPage } from "pages/settings/settings.slint";
import { ActivityPage } from "pages/activity/activity.slint";
import { ToggleSwitch } from "components/toggle_switch.slint";
import { TextField } from "components/inputs/text_field.slint";
import { DashboardPage } from "pages/dashboard/dashboard.slint";
import { AppWindowData, TabPages } from "./app_window_data.slint";
import { IconButton } from "components/buttons/icon_button.slint";
import { ScanAndCleanPage } from "pages/scan_clean/scan_clean.slint";
import { TrafficLight } from "components/window_control/traffic_light.slint";
import { WindowButtons } from "components/window_control/window_buttons.slint";
import { HorizontalDivider } from "components/divider/horizontal_divider.slint";
import {
    WindowControl,
} from "./components/window_control/global_logic/window_control_logic.slint";
import {
    Button,
    VerticalBox,
    HorizontalBox,
    GridBox,
    LineEdit,
    Switch,
} from "std-widgets.slint";

export { WindowControl, AppWindowData, SettingsPage, Theme }
export { ActivityData } from "./pages/activity/activity_data.slint";
export { SettingsData } from  "./pages/settings/settings_data.slint";
export { DashboardAdapter } from "./pages/dashboard/dashboard_data.slint";
export { CleanersData, Cleaner, CleanTarget, CleanDetect, PathType } from "pages/cleaners/cleaners_data.slint";


//======================================
// Tab
//======================================
 component Tab inherits Rectangle {

    callback on_route(TabPages);
    in-out property <TabPages> active_page;

    min-height: 700px;
    width: Theme.sidebar_width;
    background: Theme.bg_sidebar;

    VerticalBox {
        spacing: 0px;
        padding: 0px;
            
        //=============================
        // Header Section
        //=============================
        HorizontalBox {
            padding: 10px;
            spacing: 10px;

            // Display on when it is MacOS
            if Platform.os == OperatingSystemType.macos: TrafficLight { }

            Rectangle {
                width: 31px;
                height: self.width;
                background: Theme.accent;
                border-radius: Theme.radius_md;

                Image {
                    width: 13px;
                    height: self.width;
                    colorize: #ffffff;
                    source: Icons.appIcon;
                }
            }

            VerticalBox {
                padding: 0px;
                spacing: 3px;
                alignment: center;

                Text {
                    text: "DevSweep";
                    font-weight: 800;
                    font-size: 1.25rem;
                    color: Theme.accent;
                    letter-spacing: -0.5px;
                }

                Text {
                    text: "v1.0.0";
                    font-weight: 500;
                    font-size: 0.7rem;
                    color: Theme.text_tertiary;
                    font-family: Theme.font_mono;
                }
            }
        }

        HorizontalDivider {
            width: parent.width;
            background: Theme.border_primary;
        }

        //=============================
        // Body Section
        //=============================
        VerticalBox {
            spacing: 1px;
            alignment: start;
            vertical-stretch: 1;

            for item[index] in [
                { text: "Dashboard", icon: Icons.dashboard, page: TabPages.Dashboard },
                { text: "Scan & Clean", icon: Icons.search, page: TabPages.ScanClean },
                { text: "Cleaners", icon: Icons.puzzle, page: TabPages.Cleaners },
                { text: "Activity", icon: Icons.terminal, page: TabPages.Activity },
                { text: "Settings", icon: Icons.settings, page: TabPages.Settings }
            ]: NavItem {
                height: 37px;
                text: item.text;
                icon: item.icon;
                clicked => on_route(item.page);
                active: root.active_page == item.page;
            }
        }

        HorizontalDivider {
            width: parent.width;
            background: Theme.border_primary;
        }

        //=============================
        // Footer Section
        //=============================
        VerticalBox {
            spacing: 0px;
            padding: 10px;

            HorizontalBox {
                spacing: 5px;
                padding-top: 0px;
                alignment: center;
                padding-bottom: 10px;

                VerticalLayout {
                    alignment: center;

                    Image {
                        width: 15px;
                        height: self.width;
                        source: Icons.moon;
                        colorize: Theme.text_tertiary;
                    }
                }

                ToggleSwitch {
                    checked: Theme.theme == ThemeType.Light;
                    toggled => {
                        Theme.theme = self.checked ? ThemeType.Light : ThemeType.Dark;
                    }
                }

                VerticalLayout {
                    alignment: center;

                    Image {
                        width: 17px;
                        source: Icons.sun;
                        height: self.width;
                        colorize: Theme.text_tertiary;
                    }
                }
            }

            Text {
                font-size: 0.72rem;
                color: Theme.text_tertiary;
                text: "Cross-platform ~ Open Source";
                horizontal-alignment: TextHorizontalAlignment.center;
            }
        }
    }
}

//======================================
// Tab Body Header
//======================================
component BodyHeader inherits Rectangle {
    callback start_drag();

    in property <string> title;

    vertical-stretch: 0;
    height: Theme.topbar_height;
    background: Theme.bg_secondary;

    TouchArea {
        width: parent.width;
        height: parent.height;
        double-clicked => WindowControl.maximize-requested();
        pointer-event(event) => {
            if (event.button == PointerEventButton.left && event.kind == PointerEventKind.down) {
                root.start_drag();
            }
        }
    }

    HorizontalLayout {
        spacing: 10px;

        VerticalLayout {
            alignment: center;
            padding-left: 10px;

            Text {
                text: title;
                font-weight: 700;
                font-size: 1.2rem;
                horizontal-stretch: 1;
                vertical-alignment: center;
            }
        }

        VerticalLayout {
            alignment: center;

            HorizontalLayout {
                spacing: 10px;
                padding-right: 10px;
                horizontal-stretch: 0;

                TextField {
                    placeholder: "Search projects...";
                }

                HorizontalLayout {
                    spacing: 5px;

                    IconButton {
                        icon_size: 15px;
                        icon: Icons.notification;
                    }

                    IconButton {
                        icon: Icons.bolt;
                        clicked => {
                            AppWindowData.active-page = TabPages.ScanClean;
                        }
                    }
                }
            }
        }

        // Display on when it is Window or Linux
        if Platform.os == OperatingSystemType.windows || Platform.os == OperatingSystemType.linux: 
        WindowButtons { }
    }
}

//======================================
// Notification
//======================================
component Toast inherits VerticalLayout {
    in property <length> parent_height;

    width: 220px;
    spacing: 6px;
    visible: false;
    alignment: end;
    // padding: 10px; // If parent has padding, child element doesn't obey x,y value
    height: parent_height - 10px;
    x: root.width - self.width - self.spacing;
    y: root.height - self.height - self.spacing;

    for data[i] in 5: Rectangle {
        border-width: 1px;
        background: Theme.bg_card;
        border-radius: Theme.radius_sm;
        x: i == 0 ? self.width / 2 : 0px;
        border-color: Theme.border_primary;

        VerticalLayout {
            alignment: center;
            horizontal-stretch: 1;

            HorizontalLayout {
                height: 22px;
                spacing: 8px;
                padding-left: 5px;
                padding-right: 5px;

                VerticalLayout {
                    alignment: center;

                    Image {
                        width: 15px;
                        height: self.width;
                        source: Icons.info_bold;
                        colorize: Theme.success;
                    }
                }

                Text {
                    y: 1px;
                    font-size: 0.80rem;
                    text: "Toast Title";
                    color: Theme.text_primary;
                    vertical-alignment: center;
                }

                VerticalLayout {
                    alignment: center;

                    IconButton {
                        width: 15px;
                        icon: Icons.close;
                        height: self.width;
                        bg: Theme.bg_secondary;
                        icon_size: self.width * 0.5;
                    }
                }
            }

            HorizontalDivider { }

            HorizontalLayout {
                padding: 10px;

                Text {
                    wrap: word-wrap;
                    font-size: 0.78rem;
                    text: "Toast description";
                    color: Theme.text_tertiary;
                }
            }
        }
    }
}

//======================================
// 
//======================================
export component AppWindow inherits Window {
    no-frame: true;
    preferred-width: 1000px;
    preferred-height: 600px;
    background: transparent;
    resize-border-width: 5px; // haven't find it usefulness yet

    Rectangle {
        clip: true;
        width: 100%;
        height: 100%;
        border-radius: 12px;
        background: Theme.bg_primary;

        HorizontalBox {
            spacing: 0px;
            padding: 0px;

            //================================
            // Body
            //================================
            Tab {
                active-page: AppWindowData.active_page;
                on_route(page) => {
                    AppWindowData.active_page = page;
                }
            }

            //================================
            // Body
            //================================
            VerticalLayout {
                vertical-stretch: 1;
                alignment: AppWindowData.active-page == TabPages.ScanClean || AppWindowData.active-page == TabPages.Cleaners || AppWindowData.active-page == TabPages.Activity ? stretch : start;

                BodyHeader {
                    title: AppWindowData.page_title;
                    start_drag => AppWindowData.start_system_move();
                }

                // Where the (pages) will be rendered
                if AppWindowData.active-page == TabPages.Dashboard: DashboardPage { }
                if AppWindowData.active-page == TabPages.ScanClean: ScanAndCleanPage { }
                if AppWindowData.active-page == TabPages.Cleaners: CleanersPage { }
                if AppWindowData.active-page == TabPages.Activity: ActivityPage { }
                if AppWindowData.active-page == TabPages.Settings: SettingsPage { }
            }
        }

        //================================
        // Notification Dialog {}
        //================================
        Toast {
            parent_height: parent.height;
        }
    }
}

