import { Theme } from "../../theme/theme.slint";
import { SettingsData } from "settings_data.slint";
import { Icons } from "../../services/icons.slint";
import { Card, CardHeader } from "../../components/cards/card.slint";
import { GridBox, TextEdit, ComboBox } from "std-widgets.slint";
import { TextArea } from "../../components/inputs/text_area.slint";
import { ToggleSwitch } from "../../components/toggle_switch.slint";
import { TextField } from "../../components/inputs/text_field.slint";
import { IconButton } from "../../components/buttons/icon_button.slint";
import {
    HorizontalDivider,
} from "../../components/divider/horizontal_divider.slint";

//=================================
//
//=================================
component Rect inherits HorizontalLayout {
    in property <string> title;
    in property <string> label;

    spacing: 50px;
    padding-top: 10px;
    padding-bottom: 10px;
    alignment: space-between;

    VerticalLayout {
        spacing: 6px;
        alignment: start;

        Text {
            text: title;
            font-weight: 600;
            font-size: 0.9rem;
        }

        Text {
            text: label;
            font-size: 0.8rem;
            color: Theme.text_tertiary;
        }
    }

    @children
}

export component SettingsPage inherits GridBox {

    //****************************************/
    Card {

        CardHeader {
            title: "Appearance";
            source: Icons.palette;
        }

        HorizontalDivider {
            background: Theme.border_primary;
        }

        VerticalLayout {
            alignment: start;
            padding-left: 15px;
            padding-right: 15px;

            Rect {
                title: "Theme";
                label: "Choose between dark and light mode";

                ComboBox {
                    current-index: 0;
                    model: ["Dark Mode", "Light Mode", "System Default"];
                }
            }

            HorizontalDivider {
                background: Theme.border_primary.with-alpha(0.05);
            }

            Rect {
                title: "Accent Color";
                label: "Customize the primary accent color";

                VerticalLayout {
                    alignment: center;

                    HorizontalLayout {
                        spacing: 5px;
                        for data[i] in SettingsData.theme_colors: Rectangle {
                            width: 20px;
                            background: data;
                            border-width: 2px;
                            height: self.width;
                            drop-shadow-blur: 10px;
                            border-radius: self.width * Theme.radius_full;
                            drop-shadow-color: color_picker.has-hover ? data : transparent;
                            border-color: color_picker.has-hover ? Theme.text_primary : transparent;
                            color_picker := TouchArea {
                                mouse-cursor: pointer;
                                clicked => {
                                    Theme.accent = data;
                                }
                            }
                        }
                    }
                }
            }

            HorizontalDivider {
                background: Theme.border_primary.with-alpha(0.05);
            }

            Rect {
                title: "Compact Mode";
                label: "Reduce padding and margins for smaller screens";

                VerticalLayout {
                    alignment: center;
                    ToggleSwitch { }
                }
            }
        }
    }

    //****************************************/
    Card {

        CardHeader {
            title: "Safety";
            source: Icons.shield;
        }

        HorizontalDivider {
            background: Theme.border_primary;
        }

        VerticalLayout {
            alignment: start;
            padding-left: 15px;
            padding-right: 15px;

            Rect {
                title: "Confirm Before Cleaning";
                label: "Show confirmation dialog before deleting files";

                VerticalLayout {
                    alignment: center;
                    ToggleSwitch { }
                }
            }

            HorizontalDivider {
                background: Theme.border_primary.with-alpha(0.05);
            }

            Rect {
                title: "Default Dry Run";
                label: "Always start in dry-run mode for safety";

                VerticalLayout {
                    alignment: center;
                    ToggleSwitch { }
                }
            }

            HorizontalDivider {
                background: Theme.border_primary.with-alpha(0.05);
            }

            Rect {
                title: "Skip Git Repositories";
                label: "Never clean projects with uncommitted changes";

                VerticalLayout {
                    alignment: center;
                    ToggleSwitch { }
                }
            }

            HorizontalDivider {
                background: Theme.border_primary.with-alpha(0.05);
            }

            Rect {
                title: "Exclude Paths";
                label: "Directories to always skip during scans";

                TextArea {
                    width: 200px;
                    placeholder: "/usr \n/System \n/Library";
                }
            }
        }
    }

    //****************************************/
    Card {
        row: 1;

        CardHeader {
            source: Icons.folder;
            title: "Cleaners Directory";
        }

        HorizontalDivider {
            background: Theme.border_primary;
        }

        VerticalLayout {
            alignment: start;
            padding-left: 15px;
            padding-right: 15px;

            Rect {
                title: "Cleaners Config Path";
                label: "Location where cleaner JSON configs are stored";

                HorizontalLayout {
                    spacing: 5px;

                    TextField {
                        width: 150px;
                        height: 30px;
                        show_icon: false;
                        placeholder: "Cleaner Path";
                        border-radius: Theme.radius_md;
                    }

                    IconButton {
                        height: 30px;
                        width: self.height;
                        icon: Icons.folder;
                        border_hover: Theme.accent;
                        icon_size: self.width - 15px;
                        colorize_hover: Theme.accent;
                        border-radius: Theme.radius_sm;
                        clicked => {
                            //
                        }
                    }
                }
            }

            HorizontalDivider {
                background: Theme.border_primary.with-alpha(0.05);
            }

            Rect {
                title: "Auto-reload Configs";
                label: "Watch for new cleaner configs automatically";

                VerticalLayout {
                    alignment: center;
                    ToggleSwitch { }
                }
            }
        }
    }

    //****************************************/
    Card {
        row: 1;

        CardHeader {
            source: Icons.info;
            title: "About DevSweep";
        }

        HorizontalDivider {
            background: Theme.border_primary;
        }

        VerticalLayout {
            spacing: 2px;
            padding: 15px;
            alignment: start;

            HorizontalLayout {
                alignment: center;
                padding-bottom: 10px;

                Rectangle {
                    width: 64px;
                    height: self.width;
                    border-radius: Theme.radius_lg;
                    background: @linear-gradient(135deg, Theme.accent, Theme.accent_light);
                }
            }

            Text {
                text: "DevSweep";
                font-size: 1rem;
                font-weight: 600;
                horizontal-alignment: center;
            }

            Text {
                font-size: 0.82rem;
                text: "Version 1.0.0";
                color: Theme.text-tertiary;
                horizontal-alignment: center;
            }

            VerticalLayout {
                padding-top: 10px;

                Text {
                    font-size: 0.88rem;
                    wrap: TextWrap.word-wrap;
                    color: Theme.text_secondary;
                    horizontal-alignment: center;
                    text: "A cross-platform developer project cleaner. Reclaim disk space by removing build artifacts, caches, and dependencies from your dev projects.";
                }
            }

            HorizontalLayout {
                spacing: 15px;
                alignment: center;
                padding-top: 15px;
                padding-bottom: 15px;

                for data[i] in SettingsData.project_links: Rectangle {
                    border-width: 1px;
                    background: Theme.bg_tertiary;
                    border-radius: self.height * Theme.radius_full;
                    border-color: ta.has-hover ? Theme.accent : Theme.border_primary;

                    ta := TouchArea {
                        mouse-cursor: pointer;
                        clicked => {
                            //
                        }
                    }

                    HorizontalLayout {
                        spacing: 3px;
                        padding: 8px;

                        VerticalLayout {
                            alignment: center;

                            Image {
                                width: 12px;
                                source: data.icon;
                                colorize: ta.has-hover ? Theme.accent : Theme.text_tertiary;
                            }
                        }

                        Rectangle {
                            width: id.width;

                            id := Text {
                                y: 1.9px;
                                text: data.label;
                                font-weight: 500;
                                font-size: 0.82rem;
                                vertical-alignment: center;
                                color: ta.has-hover ? Theme.accent : Theme.text_tertiary;
                            }
                        }
                    }
                }
            }

            Text {
                font-size: 0.78rem;
                color: Theme.text_tertiary;
                horizontal-alignment: center;
                text: "Made with ❤️ for developers everywhere";
            }
        }
    }
}
