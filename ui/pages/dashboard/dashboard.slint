import { Theme } from "../../theme/theme.slint";
import { Icons } from "../../services/icons.slint";
import { CleanerGlobal } from "../../global/cleaner_global.slint";
import { StatCard } from "../../components/cards/stat_card.slint";
import { RectCard } from "../../components/cards/rect_card.slint";
import { Card, CardHeader } from "../../components/cards/card.slint";
import { RecentActivity } from "../../components/recent_activity.slint";
import { GlobalRecentActivity } from "../../global/activities_global.slint";
import {
    QuickAction,
    DashboardAdapter,
} from "./dashboard_data.slint";
import {
    HorizontalBox,
    ScrollView,
    ListView,
    GridBox,
} from "std-widgets.slint";
import {
    HorizontalDivider,
} from "../../components/divider/horizontal_divider.slint";
import {
    MyEmptyActivityComponent,
} from "../../components/empty_activity.slint";


//===============================
//
//===============================
component ViewMore inherits Rectangle {
    callback moreClicked();

    ta := TouchArea {
        mouse-cursor: pointer;
        clicked => moreClicked();
    }

    HorizontalLayout {
        spacing: 3px;

        Text {
            text: "View All";
            font-size: 0.82rem;
            vertical-alignment: center;
            color: ta.has-hover ? Theme.accent : Theme.accent_light;
        }

        VerticalLayout {
            y: -1.5px;
            alignment: center;

            Image {
                width: 10px;
                source: Icons.arrowRight;
                colorize: ta.has-hover ? Theme.accent : Theme.accent_light;
            }
        }
    }
}

export component DashboardPage inherits Flickable {
    horizontal-stretch: 1;
    min-width: layout.min-width + 40px;

    // property <int> value: 2;
    property <int> plugin_per_row: 4;
    property <length> prev_card_width: 0px;
    property <length> current_card_width: 1px;
    property <{ max: length,min: length}> plugin-min-max-width: { min: 200px, max: 250px };

    TouchArea {
        clicked => {
        }
        pointer-event(event) => {
        }
    }

    layout := VerticalLayout {
        padding: 20px;
        spacing: 15px;
        horizontal-stretch: 1;

        //===============================
        // Stat Cards Section
        //===============================
        HorizontalLayout {
            spacing: 15px;

            for data in DashboardAdapter.stats: StatCard {
                data: data;
            }
        }

        //===============================
        // Quick Action & Recent Section 
        //===============================
        HorizontalLayout {
            spacing: 15px;

            Card {
                width: 50%;

                CardHeader {
                    title: "Quick Actions";
                    source: Icons.quickAction;
                }

                HorizontalDivider {
                    background: Theme.border_primary;
                }

                VerticalLayout {
                    spacing: 6px;
                    padding: 15px;
                    horizontal-stretch: 1;

                    for data[i] in DashboardAdapter.quick_action: RectCard {
                        title: data.title;
                        source: data.icon;
                        description: data.sub-title;
                        _x: self.has-hover ? 4px : 0px;
                        _drop-shadow-color: Theme.accent_dark.with-alpha(0.2);
                        _drop-shadow-blur: i == 0 ? self.has-hover ? 20px : 0px : 0px;
                        desc_color: i == 0 && self.has-hover ? Theme.text_secondary : Theme.text_tertiary;
                        _border-color: i == 0 ? Theme.accent.with-alpha(self.has-hover ? 0.4 : 0.2) : self.has-hover ? Theme.border_secondary : Theme.border_primary;
                        _background: i == 0 ? @linear-gradient(135deg, Theme.accent.with-alpha(0.15), Theme.accent.with-alpha(0.05)) : self.has-hover ? Theme.bg_elevated : Theme.bg_tertiary;

                        animate _x {
                            easing: ease;
                            duration: Theme.transition_fast;
                        }

                        animate _drop-shadow-blur {
                            duration: Theme.transition_fast;
                            easing: ease;
                        }

                        VerticalLayout {
                            width: 12px;
                            alignment: center;

                            Image {
                                width: 12px;
                                height: self.width;
                                source: Icons.arrowRight;
                                colorize: Theme.text_tertiary;
                            }
                        }
                    }
                }
            }

            Card {

                CardHeader {
                    source: Icons.recent;
                    title: "Recent Activity";

                    ViewMore { }
                }

                HorizontalDivider {
                    background: Theme.border_primary;
                }

                if GlobalRecentActivity.activity.length == 0: MyEmptyActivityComponent { }

                if  GlobalRecentActivity.activity.length != 0: ListView {
                    vertical-stretch: 1;

                    for data[i] in GlobalRecentActivity.activity: RecentActivity {
                        i: i;
                        data: data;
                        length: GlobalRecentActivity.activity.length;
                    }
                }
            }
        }

        //===============================
        // Available Cleaner Section
        //===============================
        c := Card {

            CardHeader {
                title: "Available Cleaners";
                source: Icons.AvailableCleaners;

                ViewMore { }
            }

            HorizontalDivider {
                background: Theme.border_primary;
            }

            HorizontalLayout {
                alignment: start;

                GridBox {
                    width: 100%;

                    for cleaner[i] in CleanerGlobal.cleaners: RectCard {
                        title: cleaner.name;
                        source: cleaner.icon;
                        _x: self.has-hover ? 4px : 0px;
                        description: cleaner.description;
                        row: Math.floor(i / plugin_per_row);
                        max-width: plugin-min-max-width.max;
                        // min-width: plugin-min-max-width.min;

                        animate _x {
                            easing: ease;
                            duration: Theme.transition_fast;
                        }
                    }
                }
            }
        }
    }

    //===============================
    // Fragile Do Not Touch Any How
    //===============================
    timer := Timer {
        interval: 0.1ms;
        running: root.prev_card_width != root.current_card_width; // || root.prev_card_width != layout.width;
        triggered => {
            // value -= 1;
            // if(value == 1){
            prev_card_width = layout.width;
            current_card_width = layout.width;
            // }

            debug(current_card_width);
            // debug("xx \{last_card_width}");
        }
    }
}
