import { Theme } from "../../theme/theme.slint";
import { Icons } from "../../services/icons.slint";
import { ScrollView, ListView } from "std-widgets.slint";
import { ActivityLogData, FilterBy } from "activity_log_data.slint";
import { Card, CardHeader } from "../../components/cards/card.slint";
import { GroupedOption } from "../../components/grouped_option.slint";
import { RecentActivity } from "../../components/recent_activity.slint";
import { GlobalRecentActivity } from "../../global/activities_global.slint";
import {
    MyEmptyActivityComponent,
} from "../../components/empty_activity.slint";
import {
    HorizontalDivider,
} from "../../components/divider/horizontal_divider.slint";
import {
    TextIconButton,
} from "../../components/buttons/text_icon_button.slint";
import {
    VerticalDivider,
} from "../../components/divider/vertical_divider.slint";
import { TerminalLog } from "../../components/terminal_log.slint";


//==================================
//
//==================================
component ActivityTimeline inherits Card {
    CardHeader {
        spacing: 15px;
        padding-top: 12px;
        padding-bottom: 12px;
        source: Icons.recent;
        title: "Activity Timeline";

        HorizontalLayout {
            spacing: 6px;

            GroupedOption {
                data: ActivityLogData.filter_list;
                selected: ActivityLogData.filterToString(ActivityLogData.filter_by);
                clicked(val) => {
                    ActivityLogData.filter_by = ActivityLogData.stringToFilter(val);
                }
            }

            TextIconButton {
                height: 28px;
                text: "Clear";
                icon_size: 9.5px;
                border-width: 1px;
                source: Icons.trash;
                background: Theme.bg_tertiary;
                border-radius: Theme.radius_sm;
                border-color: self.has-hover ? Theme.accent : Theme.border_secondary;
                icon_color: self.has-hover ? Theme.accent_light : Theme.text_secondary;
                text_color: self.has-hover ? Theme.accent_light : Theme.text_secondary;
            }
        }
    }

    HorizontalDivider {
        background: Theme.border_primary;
    }

    if GlobalRecentActivity.activity.length == 0: MyEmptyActivityComponent { }

    if  GlobalRecentActivity.activity.length != 0: ListView {
        vertical-stretch: 1;

        for data[i] in GlobalRecentActivity.activity: RecentActivity {
            i: i;
            data: data;
            length: GlobalRecentActivity.activity.length;
        }
    }
}

//==================================
//
//==================================
component ActivityLog inherits Card {

    CardHeader {
        padding-top: 12px;
        padding-bottom: 12px;
        title: "Activity Log";
        source: Icons.terminal;

        HorizontalLayout {
            spacing: 6px;

            TextIconButton {
                height: 28px;
                text: "Export";
                icon_size: 9.5px;
                border-width: 1px;
                source: Icons.download;
                background: Theme.bg_tertiary;
                border-radius: Theme.radius_sm;
                border-color: self.has-hover ? Theme.accent : Theme.border_secondary;
                icon_color: self.has-hover ? Theme.accent_light : Theme.text_secondary;
                text_color: self.has-hover ? Theme.accent_light : Theme.text_secondary;
            }

            TextIconButton {
                height: 28px;
                text: "Clear";
                icon_size: 9.5px;
                border-width: 1px;
                source: Icons.trash;
                background: Theme.bg_tertiary;
                border-radius: Theme.radius_sm;
                border-color: self.has-hover ? Theme.accent : Theme.border_secondary;
                icon_color: self.has-hover ? Theme.accent_light : Theme.text_secondary;
                text_color: self.has-hover ? Theme.accent_light : Theme.text_secondary;
            }
        }
    }

    HorizontalDivider {
        background: Theme.border_primary;
    }

    VerticalLayout {
        padding: 15px;

        TerminalLog {
            logs: ActivityLogData.logs;
        }
    }
}

export component ActivityLogPage inherits VerticalLayout {
    padding: 15px;
    spacing: 15px;

    ActivityTimeline { }

    ActivityLog { }
}
