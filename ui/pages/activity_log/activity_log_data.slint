import { GroupedOptionData } from "../../components/grouped_option.slint";
import { LogEntry, LogStatus } from "../../components/terminal_log.slint";

export enum FilterBy {
    All,
    Scans,
    Cleans,
    Settings,
    Plugins,
}

export global ActivityLogData {
    in-out property <FilterBy> filter_by: FilterBy.All;

    in property <[GroupedOptionData]> filter_list: [
        {
            label: "All",
            value: filterToString(FilterBy.All),
        },
        {
            label: "Scans",
            value: filterToString(FilterBy.Scans),
        },
        {
            label: "Cleans",
            value: filterToString(FilterBy.Cleans),
        },
        {
            label: "Settings",
            value: filterToString(FilterBy.Settings),
        },
        {
            label: "Plugins",
            value: filterToString(FilterBy.Plugins),
        },
    ];

    in-out property <[LogEntry]> logs: [
        { message: "System initialized", timestamp: "00:00:01", status: LogStatus.Info },
        { message: "User login successful", timestamp: "00:00:15", status: LogStatus.Success },
        { message: "Failed to fetch API data", timestamp: "00:02:05", status: LogStatus.Danger },
        { message: "Cache cleared", timestamp: "00:02:50", status: LogStatus.Info },
        { message: "New message received", timestamp: "00:03:30", status: LogStatus.Info },
        { message: "Disk space low", timestamp: "00:05:00", status: LogStatus.Warning },
        { message: "User logout", timestamp: "00:05:45", status: LogStatus.Info },
        { message: "Failed login attempt", timestamp: "00:06:10", status: LogStatus.Danger },
        { message: "Background job started", timestamp: "00:06:55", status: LogStatus.Info },
        { message: "Configuration updated", timestamp: "00:08:20", status: LogStatus.Info },
        { message: "API response delayed", timestamp: "00:09:50", status: LogStatus.Warning },
        { message: "Payment processed", timestamp: "00:10:30", status: LogStatus.Success },
        { message: "Failed to send email", timestamp: "00:11:15", status: LogStatus.Danger },
        { message: "New user registered", timestamp: "00:12:00", status: LogStatus.Info },
        { message: "Session expired", timestamp: "00:12:45", status: LogStatus.Warning },
        { message: "User password changed", timestamp: "00:13:30", status: LogStatus.Success },
        { message: "Error parsing JSON", timestamp: "00:14:10", status: LogStatus.Danger },
        { message: "Temporary files cleaned", timestamp: "00:15:40", status: LogStatus.Info },
        { message: "New comment added", timestamp: "00:17:45", status: LogStatus.Info },
        { message: "Email verified", timestamp: "00:18:30", status: LogStatus.Success },
        { message: "Warning: Low battery", timestamp: "00:19:10", status: LogStatus.Warning },
        { message: "File uploaded", timestamp: "00:19:55", status: LogStatus.Success },
        { message: "Failed to load resource", timestamp: "00:20:40", status: LogStatus.Danger },
        { message: "Notification sent", timestamp: "00:21:20", status: LogStatus.Info },
        { message: "User profile updated", timestamp: "00:22:05", status: LogStatus.Success },
        { message: "Payment failed", timestamp: "00:23:30", status: LogStatus.Danger },
        { message: "Session restored", timestamp: "00:24:10", status: LogStatus.Success },
        { message: "Backup completed", timestamp: "00:24:55", status: LogStatus.Success },
        { message: "Server restarted", timestamp: "00:26:20", status: LogStatus.Danger },
        { message: "New chat message", timestamp: "00:27:00", status: LogStatus.Info },
        { message: "File deleted", timestamp: "00:29:10", status: LogStatus.Info },
        { message: "Error writing to log", timestamp: "00:29:55", status: LogStatus.Danger },
        { message: "User settings saved", timestamp: "00:30:40", status: LogStatus.Success },
        { message: "API request successful", timestamp: "00:32:00", status: LogStatus.Success },
        { message: "Cache updated", timestamp: "00:33:30", status: LogStatus.Info },
        { message: "Data exported", timestamp: "00:34:55", status: LogStatus.Success },
        { message: "Failed to delete record", timestamp: "00:35:40", status: LogStatus.Danger },
        { message: "User session cleared", timestamp: "00:36:20", status: LogStatus.Info },
    ];

    pure public function filterToString(f: FilterBy) -> string {
        return f == FilterBy.All ? "All" : f == FilterBy.Scans ? "Scans" : f == FilterBy.Cleans ? "Cleans" : f == FilterBy.Settings ? "Settings" : "Plugins";
    }

    pure public function stringToFilter(s: string) -> FilterBy {
        return s == "All" ? FilterBy.All : s == "Scans" ? FilterBy.Scans : s == "Cleans" ? FilterBy.Cleans : s == "Settings" ? FilterBy.Settings : FilterBy.Plugins;
    }
}
