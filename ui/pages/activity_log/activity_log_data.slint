export enum LogStatus {
    Info,
    Danger,
    Warning,
    Success,
}

export enum FilterBy {
    All,
    Scans,
    Cleans,
    Settings,
    Plugins,
}

export struct LogEntry {
    message: string,
    status: LogStatus,
    timestamp: string,
}

export struct FilterList {
    label: string,
    value: FilterBy,
}

export global ActivityLogData {
    in-out property <FilterBy> filter_by: FilterBy.All;
    in property <[FilterList]> filter_list: [
        {
            label: "All",
            value: FilterBy.All,
        },
        {
            label: "Scans",
            value: FilterBy.Scans,
        },
        {
            label: "Cleans",
            value: FilterBy.Cleans,
        },
        {
            label: "Settings",
            value: FilterBy.Settings,
        },
        {
            label: "Plugins",
            value: FilterBy.Plugins,
        },
    ];

